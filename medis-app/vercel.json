{
  "version": 2,
  "builds": [
    {
      "src": "server.php",
      "use": "vercel-php@0.7.4"
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/server.php"
    }
  ],
  "env": {
    "APP_STORAGE": "/tmp/medis-shams",
    "VIEW_COMPILED_PATH": "/tmp/medis-shams/framework/views",
    "APP_CONFIG_CACHE": "/tmp/medis-shams/bootstrap/cache/config.php",
    "APP_EVENTS_CACHE": "/tmp/medis-shams/bootstrap/cache/events.php",
    "APP_PACKAGES_CACHE": "/tmp/medis-shams/bootstrap/cache/packages.php",
    "APP_ROUTES_CACHE": "/tmp/medis-shams/bootstrap/cache/routes.php",
    "APP_SERVICES_CACHE": "/tmp/medis-shams/bootstrap/cache/services.php",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "LOG_CHANNEL": "stderr"
  }
}
